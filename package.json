{
    "name": "combocss",
    "version": "0.6.6",
    "description": "ComboCSS a CSS Toolkit for combining CSS properties",
    "keywords": ["combocss", "postcss", "css", "postcss-plugin", "atomic-css", "utility-css", "vite"],
    "bin": {
        "combo": "lib/cli.js"
    },
    "scripts": {
        "test": "node --test index.test.js",
        "build:browser": "rollup -c"
    },
    "author": "Benjamin Lotterer <theedgesofben@hotmail.com>",
    "license": "MIT",
    "repository": "theedgesofben/combocss",
    "engines": {
        "node": ">=16.0.0"
    },
    "dependencies": {
        "autoprefixer": "^10.4.17",
        "chokidar": "^3.6.0",
        "commander": "^9.4.1",
        "fast-glob": "^3.2.11",
        "parse5": "^6.0.1",
        "stylelint": "^16.2.0"
    },
    "peerDependencies": {
        "postcss": "^8.3.0"
    },
    "devDependencies": {
        "clean-publish": "^3.4.2",
        "eslint": "^8.0.1",
        "eslint-plugin-jest": "^25.2.2",
        "jest": "^29.7.0",
        "postcss": "^8.4.6",
        "rollup": "^4.0.0"
    },
    "prettier": {
        "tabWidth": 4,
        "printWidth": 160
    },
    "browserslist": ["last 15 version", "not dead"],
    "type": "module",
    "main": "index.js",
    "exports": {
        ".": {
            "import": "./index.js"
        },
        "./standalone": {
            "import": "./lib/standalone.js"
        },
        "./core": {
            "import": "./lib/core.js"
        },
        "./browser": {
            "import": "./browser/browser.js"
        }
    }
}
